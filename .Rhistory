knitr::opts_chunk$set(echo = TRUE)
library(tidyverse)
library(readxl)
µL <- c(0,10,30,50,60,80)
OD <- c(0,0.043,0.246,0.448,0.548,0.785)
df <- data.frame("µL" = µL, "OD" = OD)
df
ggplot(df, aes(µL, OD)) +
geom_line(
color = 'darkblue'
) +
geom_point(
color = 'darkgreen',
size = 3
) +
geom_text(aes(label = after_stat(y)), nudge_x = -5.5) +
geom_smooth(
method = 'lm',
color = 'red',
linetype = "dashed",
se = FALSE,
formula = y ~ x
) +
theme_bw()
model <- lm(OD~µL, df)
model
summary(model)
