#NEXUS
begin data;
dimensions ntax=5 nchar=516;
format datatype=protein missing=? gap=-;
matrix
aptenodytes_forsteri_COX1    
aptenodytes_patagonicus_COX1 
eudyptula_minor_COX1         
pygoscelis_adeliae_COX1      
pygoscelis_papua_COX1        
;
end;

BEGIN MRBAYES;
    set autoclose=yes;
    prset aamodelpr=mixed;
    mcmc ngen=1000000 samplefreq=500 printfreq=1000 nchains=4;
    sump burnin=250;
    sumt burnin=250;
END;
